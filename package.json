{
  "name": "servicebeard",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "dev:infra": "docker compose up -d",
    "dev:api": "bun run --filter @servicebeard/api dev",
    "dev:web": "bun run --filter @servicebeard/web dev",
    "dev:worker": "bun run --filter @servicebeard/worker dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit.test.ts",
    "test:security": "mkdir -p reports/security && bun test tests/security --reporter=junit --reporter-outfile=reports/security/junit.xml",
    "test:security:report": "bun tests/security/report.ts",
    "test:e2e": "playwright test",
    "e2e:seed": "bun tests/e2e/fixtures/seed.ts",
    "db:generate": "bun run --filter @servicebeard/db generate",
    "db:migrate": "bun run --filter @servicebeard/db migrate",
    "db:reset": "bun run --filter @servicebeard/db reset",
    "db:studio": "bun run --filter @servicebeard/db studio"
  },
  "devDependencies": {
    "@servicebeard/db": "workspace:*",
    "@servicebeard/providers": "workspace:*",
    "@servicebeard/shared": "workspace:*",
    "@playwright/test": "^1.55.0",
    "@types/bun": "latest",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  }
}
