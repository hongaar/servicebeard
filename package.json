{
  "name": "servicebeard",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "dev:infra": "docker compose up -d",
    "dev:api": "bun run --filter @servicebeard/api dev",
    "dev:web": "bun run --filter @servicebeard/web dev",
    "dev:worker": "bun run --filter @servicebeard/worker dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "bun run test:unit",
    "test:unit": "bun test apps packages",
    "test:integration": "bun run test:integration:security && bun run test:integration:security:report && bun run test:integration:ui",
    "test:integration:seed": "bun tests/e2e/fixtures/seed.ts",
    "test:integration:security": "mkdir -p reports/security && bun test tests/security --reporter=junit --reporter-outfile=reports/security/junit.xml",
    "test:integration:security:report": "bun tests/security/report.ts",
    "test:integration:ui": "playwright test",
    "db:generate": "bun run --filter @servicebeard/db generate",
    "db:migrate": "bun run --filter @servicebeard/db migrate",
    "db:reset": "bun run --filter @servicebeard/db reset",
    "db:studio": "bun run --filter @servicebeard/db studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.0",
    "@servicebeard/db": "workspace:*",
    "@servicebeard/providers": "workspace:*",
    "@servicebeard/shared": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,yml,yaml,html}": "prettier --write"
  }
}
