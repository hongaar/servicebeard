{
  "name": "@servicebeard/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "tsc -b && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./extensions": "./src/extensions/index.tsx",
    "./lib/*": "./src/lib/*",
    "./routes/*": "./src/routes/*",
    "./styles/*": "./src/styles/*"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@sentry/react": "^10.62.0",
    "@servicebeard/shared": "workspace:*",
    "@simplewebauthn/browser": "^13.3.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-router": "^1.82.0",
    "lucide-react": "0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
