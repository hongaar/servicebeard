{
  "name": "@servicebeard/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --preload ../../packages/shared/src/env-watch.ts --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./middleware/auth": "./src/middleware/auth.ts",
    "./middleware/team": "./src/middleware/team.ts",
    "./extensions": "./src/extensions.ts"
  },
  "dependencies": {
    "@sentry/bun": "^10.62.0",
    "@servicebeard/db": "workspace:*",
    "@servicebeard/mail": "workspace:*",
    "@servicebeard/providers": "workspace:*",
    "@servicebeard/shared": "workspace:*",
    "@simplewebauthn/server": "^13.3.1",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "imapflow": "^1.0.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0",
    "openid-client": "^6.0.0",
    "pg-boss": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.0",
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.6.0"
  }
}
