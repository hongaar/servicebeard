# Vite build-time variables (embedded in the web bundle).
# Generated from deploy/compose/.env by: bun run deploy/compose/extract-vite-env.ts
# Prefixes match apps/web/vite.config.ts envPrefix (VITE_*, CLOUD_PLAN_*).
